# Ghostty Configuration — Cross-Platform
# Managed via gconfig | Supports Linux and macOS

# Dynamic theme colors (omarchy theme system — fallback to Tokyo Night)
config-file = ?"~/.config/omarchy/current/theme/ghostty.conf"

# Fallback theme (used when omarchy theme has no ghostty.conf)
theme = TokyoNight
selection-background = #364a82
selection-foreground = #c0caf5

# Font
font-family = "JetBrainsMono Nerd Font"
font-style = Regular
font-size = 11
font-thicken = true

# Ligatures
font-feature = +calt,+liga

# Unicode/box-drawing rendering
grapheme-width-method = unicode

# Window
window-padding-x = 14
window-padding-y = 14
confirm-close-surface = false
resize-overlay = never

# Cursor
cursor-style = block
cursor-style-blink = false

# Shell integration (zsh, no cursor override)
shell-integration-features = no-cursor,ssh-env

# Visual polish
minimum-contrast = 1.1

# Mouse
copy-on-select = clipboard
mouse-scroll-multiplier = 0.95

# Platform-specific settings (auto-detected by gconfig setup)
config-file = ?"~/.config/ghostty/platform/current.conf"

# Keybinds (auto-detected by gconfig setup)
config-file = ?"~/.config/ghostty/keybinds/current.conf"
